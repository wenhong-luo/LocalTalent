# LocalTalent Phase III environment template
# This file contains placeholders only. Do not put real secrets in git.

# Environment: local | staging | gray
LOCALTALENT_ENV=local

# Feature flags are documented in docs/Phase_III/feature_flags.md.
# All Phase III feature flags must default to off.
PHASE3_FEATURE_PHASE3_BASELINE_GATE=off
PHASE3_FEATURE_OIDC_LOGIN=off
PHASE3_FEATURE_LOCAL_JWT_FALLBACK=off
PHASE3_FEATURE_CANDIDATE_CLOSURE=off
PHASE3_FEATURE_RESUME_ATTACHMENT_UPLOAD=off
PHASE3_FEATURE_RESUME_AI_ASSIST=off
PHASE3_FEATURE_COMPANY_WORKBENCH=off
PHASE3_FEATURE_COMPANY_STYLE_UPLOAD=off
PHASE3_FEATURE_COMPANY_LOGO_UPLOAD=off
PHASE3_FEATURE_OPERATOR_PORTAL_OPS=off
PHASE3_FEATURE_AUDIT_SECURITY_GATE=off
PHASE3_FEATURE_GRAY_OPS=off

# Runtime backend switch used by Prompt 27 candidate closure. Keep false unless explicitly testing P3-2.
LOCALTALENT_PHASE3_CANDIDATE_CLOSURE=false
# Runtime backend switch used by Prompt 27 private resume attachment upload. Keep false unless explicitly testing P3-2 attachment flow.
LOCALTALENT_PHASE3_RESUME_ATTACHMENT_UPLOAD=false
LOCALTALENT_RESUME_ATTACHMENT_MAX_BYTES=5242880
# Runtime backend switch used by the safe rule-based private resume AI assist. Keep false unless explicitly testing P3-2 AI suggestions.
LOCALTALENT_PHASE3_RESUME_AI_ASSIST=false
# Runtime backend switch used by Prompt 28 company workbench. Keep false unless explicitly testing P3-3.
LOCALTALENT_PHASE3_COMPANY_WORKBENCH=false
# Runtime backend switch used by the private company style image upload. Depends on company workbench.
LOCALTALENT_PHASE3_COMPANY_STYLE_UPLOAD=false
LOCALTALENT_COMPANY_STYLE_IMAGE_MAX_BYTES=5242880
# Runtime backend switch used by the private company logo upload. Depends on company workbench.
LOCALTALENT_PHASE3_COMPANY_LOGO_UPLOAD=false
LOCALTALENT_COMPANY_LOGO_MAX_BYTES=2097152
# Runtime backend switch used by Prompt 29 operator portal ops. Keep false unless explicitly testing P3-4.
LOCALTALENT_PHASE3_OPERATOR_PORTAL_OPS=false
# Runtime ops switch used by Prompt 31 gray drills. Keep false unless explicitly running gray rehearsal.
LOCALTALENT_PHASE3_GRAY_OPS=false

# Backend datasource placeholders
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/localtalent?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=localtalent_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_LOCAL_ONLY

# Redis placeholder
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Object storage / MinIO placeholders
LOCALTALENT_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
LOCALTALENT_OBJECT_STORAGE_BUCKET=localtalent-phase3-local
LOCALTALENT_OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME_LOCAL_ONLY
LOCALTALENT_OBJECT_STORAGE_SECRET_KEY=CHANGE_ME_LOCAL_ONLY
LOCALTALENT_EXPORT_DOWNLOAD_TTL_SECONDS=900
LOCALTALENT_EXPORT_MAX_DOWNLOAD_COUNT=1

# Next / frontend placeholders
LOCALTALENT_API_BASE_URL=http://localhost:8080
LOCALTALENT_FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_LOCALTALENT_SITE_URL=http://localhost:3000

# Gray rollout placeholders. Keep conservative defaults.
LOCALTALENT_GRAY_PERCENT=0
LOCALTALENT_GRAY_USER_WHITELIST=
LOCALTALENT_GRAY_COMPANY_WHITELIST=
LOCALTALENT_GRAY_OPERATOR_WHITELIST=

# OIDC placeholders for Prompt 26. Keep disabled until Prompt 26 implements it.
LOCALTALENT_OIDC_ENABLED=false
LOCALTALENT_OIDC_ISSUER_URI=https://issuer.example.invalid
LOCALTALENT_OIDC_CLIENT_ID=CHANGE_ME_CLIENT_ID
LOCALTALENT_OIDC_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
LOCALTALENT_OIDC_REDIRECT_URI=http://localhost:8080/api/auth/oidc/callback
LOCALTALENT_OIDC_SCOPES=openid email profile
LOCALTALENT_OIDC_STATE_SECRET=CHANGE_ME_OIDC_STATE_SECRET
LOCALTALENT_OIDC_FRONTEND_BASE_URL=http://localhost:3000

# Dev/test fallback only. Must stay disabled in staging/gray unless explicitly approved.
LOCALTALENT_LOCAL_JWT_FALLBACK_ENABLED=false
LOCALTALENT_LOCAL_JWT_FALLBACK_WHITELIST=
LOCALTALENT_JWT_SECRET=CHANGE_ME_LOCAL_DEV_SECRET_ONLY

# Logging and audit placeholders
LOCALTALENT_LOG_SENSITIVE_MASKING_ENABLED=true
LOCALTALENT_AUDIT_TRACE_REQUIRED=true

# Phase III backup / restore drill placeholders. These are local/staging rehearsal values.
LOCALTALENT_DB_CONTAINER=localtalent-mysql
LOCALTALENT_DB_NAME=localtalent
LOCALTALENT_DB_USER=root
LOCALTALENT_DB_PASSWORD=CHANGE_ME_LOCAL_ONLY
LOCALTALENT_PHASE3_BACKUP_DIR=/tmp/localtalent-phase3-backups
LOCALTALENT_RESTORE_DRILL_DB=localtalent_restore_drill
KEEP_DRILL_DB=false

# Object lifecycle and export retention placeholders.
LOCALTALENT_OBJECT_RETENTION_DAYS=7
LOCALTALENT_EXPORT_FILE_RETENTION_DAYS=7
LOCALTALENT_EXPORT_CLEANUP_DRY_RUN=true

# Phase III smoke/load placeholders.
LOCALTALENT_PHASE3_SMOKE_TRACE_ID=phase3-smoke-local
LOCALTALENT_PHASE3_LOAD_ROUNDS=2
LOCALTALENT_PHASE3_LOAD_CONCURRENCY=2
LOCALTALENT_PHASE3_LOAD_P95_MS=1500
LOCALTALENT_PHASE3_LOAD_MAX_FAILURE_RATE=0

# Phase III monitoring and alert threshold placeholders.
LOCALTALENT_ALERT_HEALTH_FAIL_COUNT=3
LOCALTALENT_ALERT_PUBLIC_5XX_RATE=0.01
LOCALTALENT_ALERT_PUBLIC_P95_MS=1500
LOCALTALENT_ALERT_LOGIN_FAILURE_RATE=0.05
LOCALTALENT_ALERT_EXPORT_FAILURE_RATE=0.03
LOCALTALENT_ALERT_AUDIT_TRACE_REQUIRED=true
LOCALTALENT_ALERT_WITHDRAWAL_PUBLIC_VISIBLE_ALLOWED=false
