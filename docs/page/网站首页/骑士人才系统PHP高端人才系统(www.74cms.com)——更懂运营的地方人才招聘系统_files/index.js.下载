function loadTencent() {
    if (window.BMap !== undefined) {
        return
    }
    var script = document.createElement('script')
    script.type = 'text/javascript'
    script.src = 'https://turing.captcha.qcloud.com/TCaptcha.js'
    document.body.appendChild(script)
}

function loadVaptcha() {
    if (window.BMap !== undefined) {
        return
    }
    var script = document.createElement('script')
    script.type = 'text/javascript'
    script.src = 'https://v.vaptcha.com/v3.js'
    document.body.appendChild(script)
}

if (parseInt(qscms.captcha_open) == 1) {
    if (qscms.captcha_type == 'tencent') {
        loadTencent()
    } else if (qscms.captcha_type == 'vaptcha') {
        loadVaptcha()
    } else if(qscms.captcha_type == 'qscms'){
        // 骑士验证码
        qsCaptchaLoad()
    }
}

$(document).ready(function() {
    $(function() {
        // 图片懒加载
        $("img").lazyload({
            effect: "fadeIn"
        });

        // 首页向上滚动，右侧滚动条样式不变
        window.addEventListener('scroll', function() {
            let t = $('body, html').scrollTop();
            $('.rt_nav_box').addClass('scroll_rt_nav_box_0')
        })

        // 职位分类瀑布流 start
        $('.jno_item').hover(function() {
            $(this).find('.jno_item_pop').css('display', 'block')
            var boxWidth = 715
            if ($(this).hasClass('jno_item_all')) {
                return false
            }
            var boxArr = $(this).find('.jno_item_pop_container'),
                num = Math.floor(boxWidth / boxArr.eq(0).outerWidth(true)),
                columnHeightArr = [];
            columnHeightArr.length = num;
            boxArr.each(function(index, item) {
                if (index < num) {
                    columnHeightArr[index] = $(item).outerHeight(true);
                } else {
                    var minHeight = Math.min.apply(null, columnHeightArr),
                        minHeightIndex = $.inArray(minHeight, columnHeightArr);
                    $(item).css({
                        position: 'absolute',
                        top: minHeight,
                        left: boxArr.eq(minHeightIndex).position().left
                    });
                    columnHeightArr[minHeightIndex] += $(item).outerHeight(true);
                }
            });
        }, function() {
            $(this).find('.jno_item_pop').css('display', 'none')
        })
        // 职位分类瀑布流 end

        // 轮播广告位1
        var swiper1 = new Swiper('#J_sw1', {
            autoplay: true,
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            }
        });
        // 轮播广告位2
        // var swiper2 = new Swiper('#J_sw2', {
        //     autoplay: true,
        //     pagination: {
        //         el: '.swiper-pagination',
        //         clickable: true,
        //     }
        // });

        // 鼠标悬浮广告位
        $('#da-thumbs > li').each(function() {
            $(this).hoverdir()
        });
        // 网站动态滚动
        function textSlide(liveNum, a, b) {
            liveNum.animate({
                marginLeft: "-360px"
            }, "slow", function() {
                liveNum.children().slice(a, b).remove().appendTo(liveNum);
                liveNum.css({
                    marginLeft: 0
                })
            })
        }
        // 网站动态轮播
        var applyLive = $(".app_live ul");
        var myInt;
        $('.app_live').hover(function() {
            clearInterval(myInt);
        }, function() {
            myInt = setInterval(function() {
                textSlide(applyLive, 0, 1)
            }, 3000);
        }).trigger("mouseleave")
        // 公告滚动
        var $announcements = $('#announcement ul li');
        var currentIndex = 0;

        startCarousel();

        function startCarousel() {
            setInterval(function() {
                var $currentAnnouncement = $announcements.eq(currentIndex);
                var $nextAnnouncement = $currentAnnouncement.next();

                if ($nextAnnouncement.length === 0) {
                    $nextAnnouncement = $announcements.first();
                }

                $currentAnnouncement.animate({
                    'margin-top': '-30px'
                }, 500, function() {
                    $(this).css('margin-top', 0).appendTo($(this).parent());
                });

                $nextAnnouncement.css('margin-top', '30px').animate({
                    'margin-top': 0
                }, 500);

                currentIndex = (currentIndex + 1) % $announcements.length;
            }, 2500);
        }
    })
})


