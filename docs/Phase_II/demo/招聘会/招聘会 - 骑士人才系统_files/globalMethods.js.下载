let bind_timer
function popupWechatQrcodeWindow(val, content, reload) {
  if (true === whetherPopupWeChatQrcodeWindow(val)) {
    var requestUrl = qscms.apiUrl + qscms.apiList.member_account
    httppost(requestUrl).then((res) => {
      if (parseInt(res.data.bind_weixin) === 0) {
        httpget(qscms.apiList.qrcode, { type: "bind_weixin" })
          .then(function (res) {
            if (res.data) {
              let html = `
              <div class="wx_img global_wx" style="text-align: center;">
                    <div>
                        <img src="${res.data}" width="215" height="215"/>
                    </div>
                    <p class="wx_p1" style="font-size: 14px;color: #4CBF00;display: flex;align-items: center;justify-content: center;">
                        <span class="wx_p1_span1" style="background: url('/assets/images/weixin_ico.png') center center no-repeat;display: inline-block;width: 16px;height: 16px;background-size: 100% 100%;margin-right: 8px;"></span>
                        <span class="wx_p1_span2">微信扫一扫</span>
                    </p>
                    <p class="wx_p2" style="font-size: 16px;color: #000000;box-sizing: border-box;padding: 15px 0;">
                        ${content}
                    </p>
              </div>
              `
              let dialog_params = {
                title: "",
                content: html,
                className: "global_wx_wapper",
                reload: reload
              }
              QSdialog(dialog_params)
              whetherPopupWeChatQrcodeWindow(val, true)
              bind_timer = setInterval(function(){
                verifyWeChatBind(true)
              }, 3000)
            }
          })
          .catch(function () {})
      } else {
        if(!reload){
          return
        }
        setTimeout(() => {
          window.location.reload()
        }, 2000)
      }
    })
  } else {
    if(!reload){
      return
    }
    setTimeout(() => {
      window.location.reload()
    }, 2000)
  }
}

// 查看微信是否已绑定，绑定后自动关闭二维码
function verifyWeChatBind(isReload) {
  httpget(qscms.apiList.imCheckBind).then((res) => {
    if (res.code == 200) {
      if (res.data == 1) {
        // 删除绑定微信弹窗
        QSdialogClose()
        // 清楚定时器
        clearInterval(bind_timer)
        QSmessage("绑定成功")
        if(isReload){
          setTimeout(() => {
            window.location.reload()
          }, 2000)
        }
      }
    }
  })
}

