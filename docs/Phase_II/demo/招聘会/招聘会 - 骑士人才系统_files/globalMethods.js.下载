// cookie存储
function setCookie(key, value, days) {
  var expires = new Date()
  expires.setTime(expires.getTime() + days * 24 * 60 * 60 * 1000)
  var cookieValue =
    encodeURIComponent(key) +
    "=" +
    encodeURIComponent(value) +
    "; expires=" +
    expires.toUTCString() +
    "; path=/"
  document.cookie = cookieValue
}


