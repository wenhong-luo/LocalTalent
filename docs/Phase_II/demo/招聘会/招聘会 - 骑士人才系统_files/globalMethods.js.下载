// 开始聊天操作
// id 简历/职位id,type:1企业,2个人
function startIm(funParam, type) {
  try {
    var params = {
      token: qscms.imToken,
      jobid: funParam.jobid === undefined ? '' : funParam.jobid,
      resumeid: funParam.resumeid === undefined ? '' : funParam.resumeid
    }
    httppost(qscms.apiList.imStart, params)
      .then((res) => {
        if (res.data.next == "") {
          let href = ""
          if (type == 1 || funParam.type == 1) { 
            href = qscms.locationList.companyIm + "?chat=" + res.data.chatid
          } else {
            href = qscms.locationList.personalIm + "?chat=" + res.data.chatid
          }
          location.href = href
          return false
        }
        if (res.data.next == "disabled") {
          let messageBox = {
            content: res.message
          }
          QSmessageBox(messageBox)
          return false
        }
        if (res.data.next == "bind_weixin") {
          if(type == 1 || funParam.type == 1){
             bindwx_im(false)
          }else{
            bindwx_im(true)
          }
          return false
        }
        if (res.data.next == "choose_job") {
          chooseJob(funParam.resumeid)
          return false
        }
        if (res.data.next == "pay") {
          let messageBox = {
            content: res.message,
            confirmButtonText: "升级套餐",
            callbackConfirm: "jumpUrl",
            val1: qscms.locationList.companyService,
            cancelButtonText: "购买增值包",
            callbackCancel: "jumpUrl",
            val2: qscms.locationList.companyServiceIm
          }
          QSmessageBox(messageBox)
          return false
        }
        if (res.data.next == "complete_resume") {
          let messageBox = {
            content: res.message,
            confirmButtonText: "去完善简历",
            callbackConfirm: "jumpUrl",
            val1: qscms.locationList.personalResume
          }
          QSmessageBox(messageBox)
          return false
        }
      })
      .catch((error) => {
        let dialog_params = {
          errorMsg: error.message,
          code: error.code
        }
        errorMethods(dialog_params)
      })
  } catch (err) {
    console.log(err, "startIm")
  }
}

