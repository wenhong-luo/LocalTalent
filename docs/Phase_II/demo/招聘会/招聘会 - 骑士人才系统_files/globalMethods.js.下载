// 创建弹窗元素
// params:{
//    title:标题,
//    content:内容,
//    appendId:被添加的vue根元素标签id(不传的话默认为app)
//    funName:回调函数方法名
//    funParam:回调函数参数
//    errorMsg:提示消息
//    className:弹窗额外class类名(不传的话默认白色背景)
//    reload:关闭时是否需要刷新页面
// }
function QSdialog(params) {
  params.funParam = encodeURIComponent(JSON.stringify(params.funParam))
  try {
    var html = `
                <div class="qs_dialog_modal" id="QSdialog">
                  <div class="qs_dialog">
                    <div class="qs_dialog_wapper">
                      <div class="qs_dialog_top">
                          <div class="qs_dialog_title">
                              ${params.title}
                          </div>
                          <div class="qs_dialog_close_wapper">
                            <div class="qs_dialog_close"></div>
                          </div>
                      </div>
                      <div class="errorMsg">
                        
                      </div>
                      <div class="qs_dialog_content">
                          ${params.content}
                      </div>
                      <input type="hidden" class="nextFun" value="${params.funName}"/>
                      <input type="hidden" class="nextFunParam" value="${params.funParam}"/>
                    </div>
                  </div>
                </div>
             `

    // 添加到页面vue根元素中
    if (params.appendId) {
      $("#" + params.appendId).append(html)
      $("#QSdialog").fadeIn(100)
    } else {
      $("#app").append(html)
      $("#QSdialog").fadeIn(100)
    }
    // 添加错误消息
    if (params.errorMsg) {
      let errorHTML = `
                          <div class="qs_dialog_errorMsg">
                              <div class="qs_dialog_errorMsg_content">
                                ${params.errorMsg}
                              </div>
                          </div>
                        `
      $(".errorMsg").html(errorHTML)
    }
    // 添加额外class类名
    if (params.className) {
      $(".qs_dialog_wapper").addClass(params.className)
    }
    document.body.style.overflow = "hidden"

    // 弹窗关闭事件
    $(".qs_dialog_close").on("click", function () {
      $("#QSdialog").fadeOut(200)
      setTimeout(() => {
        $("#QSdialog").remove()
        // 如果有简历详情的弹窗开启,防止关闭其他弹窗时导致页面滚动
        if ($(".resume_show_box").length > 0) {
          return
        }
        document.body.style.overflow = "auto"
      }, 200)
      if (params.reload) {
        window.location.reload()
      }
    })
    $(".qs_dialog").on("click", function (event) {
      if (event.target == this) {
        if ($(this).find(".login_dialog_wapper").length > 0) {
          // 登录弹窗点击空白不关闭
          return
        }
        $("#QSdialog").fadeOut(200)
        setTimeout(() => {
          $("#QSdialog").remove()
          // 如果有简历详情的弹窗开启,防止关闭其他弹窗时导致页面滚动
          if ($(".resume_show_box").length > 0) {
            return
          }
          document.body.style.overflow = "auto"
        }, 200)
        if (params.reload) {
          window.location.reload()
        }
      }
    })
  } catch (err) {
    console.log(err, "QSdialog")
  }
}

// 关闭弹窗
function QSdialogClose() {
  $("#QSdialog").fadeOut(200)
  setTimeout(() => {
    $("#QSdialog").remove()
    document.body.style.overflow = "auto"
  }, 200)
}

// 成功消息提示
// msg:内容
function QSmessage(msg) {
  var html = `
                <div class="qs_message">
                  <div class="success-icon"></div>
                    ${msg}
                </div>
              `
  $("body").append(html)
  setTimeout(() => {
    $(".qs_message").addClass("qs_message_fadeIn")
  }, 100)
  setTimeout(() => {
    $(".qs_message").remove("qs_message_fadeIn").addClass("qs_message_fadeOut")
    $(".qs_message")
  }, 1500)
}

// 消息对话框
// content:内容,
// confirmButtonText/cancelButtonText:确认/取消按钮文字(不传默认:确认/取消)
// callbackConfirm/callbackCancel:确认/取消按钮执行函数方法名(不传默认关闭弹窗)
function QSmessageBox(params) {
  try {
    if (!params.confirmButtonText) {
      params.confirmButtonText = "确认"
    }
    if (!params.cancelButtonText) {
      params.cancelButtonText = "取消"
    }
    if (params.val1) {
      params.val1 = JSON.stringify(params.val1)
    }
    if (params.val2) {
      params.val2 = JSON.stringify(params.val2)
    }
    var html = `
            <div class="qs_dialog qs_messagebox_center" id="QSmessageBox">
              <div class="qs_messagebox">
                <div class="qs_messagebox_title">
                  <div>提示</div>
                  <div class="qs_dialog_close"></div>
                </div>
                <div class="qs_messagebox_content">
                  <div class="msg_icon"></div>
                  ${params.content}
                </div>
                <div class="qs_messagebox_btnWapper">
                  <div class="btn btn1">${params.cancelButtonText}</div>
                  <div class="btn btn2">${params.confirmButtonText}</div>
                </div>
                <input type="hidden" class="val1" value="${params.val1}"/>
                <input type="hidden" class="val2" value="${params.val2}"/>
              </div>
            </div>
  `
    $("body").append(html)
    // 确认按钮执行操作
    $(".qs_messagebox_btnWapper .btn2").on("click", function () {
      if (params.callbackConfirm) {
        eval(params.callbackConfirm + "(" + params.val1 + ")")
      } else {
        $("#QSmessageBox").fadeOut(200)
        setTimeout(() => {
          $("#QSmessageBox").remove()
          document.body.style.overflow = "auto"
        }, 200)
      }
    })
    // 取消按钮执行操作
    $(".qs_messagebox .btn1").on("click", function () {
      if (params.callbackCancel) {
        eval(params.callbackCancel + "(" + params.val2 + ")")
      } else {
        $("#QSmessageBox").fadeOut(200)
        setTimeout(() => {
          $("#QSmessageBox").remove()
          document.body.style.overflow = "auto"
        }, 200)
      }
    })

    // 对话框关闭事件
    $(".qs_dialog_close").on("click", function () {
      $("#QSmessageBox").fadeOut(200)
      setTimeout(() => {
        $("#QSmessageBox").remove()
        document.body.style.overflow = "auto"
      }, 200)
    })
    $(".qs_dialog").on("click", function (event) {
      if (event.target == this) {
        $("#QSmessageBox").fadeOut(200)
        setTimeout(() => {
          $("#QSmessageBox").remove()
          document.body.style.overflow = "auto"
        }, 200)
      }
    })
  } catch (err) {
    console.log(err, "QSmessageBox")
  }
}

// 执行传入的回调方法
function QSdialogCallBack() {
  try {
    var nextFun = $(".nextFun").val()
    var nextFunParam = $(".nextFunParam").val()
    QSdialogClose()
    nextFunParam = decodeURIComponent(nextFunParam)
    nextFunParam = JSON.parse(nextFunParam)
    window[nextFun](nextFunParam)
    // eval(nextFun + "(" + nextFunParam + ")")
  } catch (err) {
    console.log(err,'QSdialogCallBack');
  }
}

