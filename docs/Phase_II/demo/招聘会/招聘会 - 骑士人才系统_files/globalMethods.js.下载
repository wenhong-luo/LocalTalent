// 使用骑士验证码
function qsCaptchaShow(){
  return new Promise((resolve, reject) => {
      const divElement = document.createElement('div');
      divElement.innerHTML = `
          <div class="qscms_captcha_wrapper">
              <div class="qscms_captcha_dialog">
                  <div class="title">
                      请完成下方验证
                      <div class="close" id="qscms_captcha_close"></div>
                  </div>
                  <div id="qscms_captcha"></div>
              </div>
          </div>
      `;
      document.body.appendChild(divElement);
      $('.qscms_captcha_wrapper').css('display', 'block');
      $('#qscms_captcha_close').click(function() {
          $('.qscms_captcha_wrapper').css('display', 'none');
          $('.qscms_captcha_wrapper').remove();
      });
      $('#qscms_captcha').sliderCaptcha({
          appkey:qscms.captcha_qscms_appkey, // appkey
          onSuccess: function(ticket) {
            $('.qscms_captcha_wrapper').css('display', 'none');
            $('.qscms_captcha_wrapper').remove();
            resolve(ticket)
          },
          onFail:(res)=>{
            $('.qscms_captcha_wrapper').css('display', 'none');
            window.ELEMENT.Message.error(res.message);
          }
      });
  });
}