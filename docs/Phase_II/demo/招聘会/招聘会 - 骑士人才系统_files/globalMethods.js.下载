// 个人/企业会员err方法
function errorMethods(dialog_err) {
  try {
    let dialog_params = {
      funName: dialog_err.funName,
      funParam: dialog_err.funParam,
      errorMsg: dialog_err.errorMsg
    }
    switch (dialog_err.code) {
      // 个人会员 需要登录
      case 50010:
        doLoginDialog(dialog_params, 2)
        break
      //个人会员 需要创建简历
      case 50007:
        resumeAddDialog(dialog_params, dialog_err.isApply)
        break
      // 企业会员 需要登录
      case 50011:
        doLoginDialog(dialog_params, 1)
        break
      case 50009:
        doLoginDialog(dialog_params, 1)
        break
      // 企业会员 需要完善企业资料
      case 50003:
        let params = {
          content: dialog_err.errorMsg,
          confirmButtonText: "去填写",
          callbackConfirm: "jumpUrl",
          val1: qscms.locationList.companyInfo
        }
        QSmessageBox(params)
        break
      default:
        break
    }
  } catch (err) {
    console.log(err, "errorMethods")
  }
}

