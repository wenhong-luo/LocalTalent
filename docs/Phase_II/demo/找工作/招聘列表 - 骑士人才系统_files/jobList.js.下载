$(document).ready(function() {
    $(function() {
        // ***** 列表请求二维码
        var requestTimer;
        $('.wx_qrcode').on('click',function(){
            var job_id = $(this).data('id')
            //var share_url = JSON.stringify($(this).data('url'))
            // requestTimer = setTimeout(function(){
            var post_url = $(this).data('url')
            $('.hover_img').hide()
            $('#show_wx_qrcode_'+job_id).find('.hover_img').show()
            $('#wx_qrcode_'+job_id).attr('src', post_url);
            // requestTimer = null;
            // },500)
        })
        $('.wx_qrcode').on('mouseleave',function(){
            setTimeout(function(){
                $('.hover_img').hide()
            },100)

        })
        // ***** 列表请求二维码
        
        $('.hand_in_resume').on('click', function(event) {
            event.preventDefault();
            id = $(this).data('id')
            doApplyList(id)
        });
        function loadTencent() {
            if (window.BMap !== undefined) {
                return
            }
            var script = document.createElement('script')
            script.type = 'text/javascript'
            script.src = 'https://turing.captcha.qcloud.com/TCaptcha.js'
            document.body.appendChild(script)
        }

        function loadVaptcha() {
            if (window.BMap !== undefined) {
                return
            }
            var script = document.createElement('script')
            script.type = 'text/javascript'
            script.src = 'https://v.vaptcha.com/v3.js'
            document.body.appendChild(script)
        }

        if (parseInt(qscms.captcha_open) == 1) {
            if (qscms.captcha_type == 'tencent') {
                loadTencent()
            } else if (qscms.captcha_type == 'vaptcha') {
                loadVaptcha()
            }else if(qscms.captcha_type == 'qscms'){
                // 骑士验证码
                qsCaptchaLoad()
            }
        }

        // 职位点击标题变色 start
        var isLoginLocal = localStorage.getItem('isLogin');
        var isLogin = window.qscms.isLogin;
        if (!isLogin == isLoginLocal) { //登录状态改变时清空缓存数据
            localStorage.setItem('selectArr', []); //职位
            setCookie("selectArr", JSON.stringify([]))//用来查询看过的职位
            localStorage.setItem('selectResumeArr', []); //简历
            localStorage.setItem('selectComArr', []); //企业
        }
        
        var selectArrOnload = localStorage.getItem('selectArr') == null ||
            localStorage.getItem('selectArr') == 'null' ||
            localStorage.getItem('selectArr') == '' ||
            localStorage.getItem('selectArr') == undefined || localStorage.getItem('selectArr').data == null ? [] : JSON.parse(
                localStorage.getItem('selectArr'))
        preResumelist()

        function preResumelist() {
            for (let j of selectArrOnload) {
                $(".job_title").each(function() {
                    if ($(this).data('id') == j) {
                        $(this).addClass('job_title_active')
                    }
                });
            }
        }
        var selectArr = selectArrOnload
        $('.job_text').click(function(e) {
            if (!$(this).find(".job_title").hasClass('job_title_active')) {
                var select_id = $(this).find(".job_title").data('id')
                selectArr.push(select_id)
                var selectArrCookie = selectArr.length > 5 ? selectArr.slice(-5).reverse() :
                    selectArr.reverse()
                var selectArrStr = JSON.stringify(selectArr)
                localStorage.setItem('selectArr', selectArrStr)
                let newArr = selectArrCookie.join(',')
                setCookie("selectArr", JSON.stringify(newArr))//用来查询看过的职位
                if (!$(this).find(".job_title").hasClass('job_title_active')) {
                    $(this).find(".job_title").addClass('job_title_active')
                }
            }
        });
        // 职位点击标题变色 end
        $('.J_allListBox .job_list2 .duty_list li').addClass('substring9')
        $('.J_allListBox :last-child .duty_list li').removeClass('substring9').addClass(
            'substring2')
    })
})

