#!/usr/bin/env bash
set -euo pipefail

CONTAINER=${LOCALTALENT_DB_CONTAINER:-localtalent-mysql}
DB_USER=${LOCALTALENT_DB_USER:-root}
DB_PASSWORD=${LOCALTALENT_DB_PASSWORD:-localtalent_root}
DRILL_DB=${LOCALTALENT_RESTORE_DRILL_DB:-localtalent_restore_drill}
BACKUP_FILE=${LOCALTALENT_PHASE3_BACKUP_FILE:-}
KEEP_DRILL_DB=${KEEP_DRILL_DB:-false}

if [ -z "$BACKUP_FILE" ]; then
  echo "FAIL: set LOCALTALENT_PHASE3_BACKUP_FILE to a dump created by scripts/backup_phase3_mysql"
  exit 1
fi

if [ ! -s "$BACKUP_FILE" ]; then
  echo "FAIL: backup file missing or empty: $BACKUP_FILE"
  exit 1
fi

if [ "$DRILL_DB" = "localtalent" ]; then
  echo "FAIL: restore drill refuses to overwrite production/local database: $DRILL_DB"
  exit 1
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "FAIL: docker not found"
  exit 1
fi

if ! docker ps --format '{{.Names}}' | grep -Fxq "$CONTAINER"; then
  echo "FAIL: MySQL container not running: $CONTAINER"
  exit 1
fi

mysql_exec() {
  docker exec "$CONTAINER" sh -c \
    "MYSQL_PWD=\"\$1\" mysql -u\"\$2\" -N -B -e \"\$3\"" \
    sh "$DB_PASSWORD" "$DB_USER" "$1"
}

mysql_exec "DROP DATABASE IF EXISTS \`$DRILL_DB\`; CREATE DATABASE \`$DRILL_DB\` CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci;"

docker exec -i "$CONTAINER" sh -c \
  "MYSQL_PWD=\"\$1\" mysql -u\"\$2\" \"\$3\"" \
  sh "$DB_PASSWORD" "$DB_USER" "$DRILL_DB" < "$BACKUP_FILE"

required_tables=(
  "flyway_schema_history"
  "company"
  "job_post"
  "candidate_publish_snapshot"
  "export_apply"
  "audit_log"
)

for table_name in "${required_tables[@]}"; do
  count=$(mysql_exec "SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='$DRILL_DB' AND table_name='$table_name';")
  if [ "$count" != "1" ]; then
    echo "FAIL: restored drill database missing table: $table_name"
    exit 1
  fi
done

flyway_count=$(mysql_exec "SELECT COUNT(*) FROM \`$DRILL_DB\`.flyway_schema_history;")
if [ "$flyway_count" -lt 1 ]; then
  echo "FAIL: restored drill database has no Flyway history"
  exit 1
fi

if [ "$KEEP_DRILL_DB" != "true" ]; then
  mysql_exec "DROP DATABASE IF EXISTS \`$DRILL_DB\`;"
fi

echo "PASS: restored $BACKUP_FILE into $DRILL_DB"
