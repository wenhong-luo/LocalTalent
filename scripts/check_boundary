#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
README_FILE="$ROOT_DIR/README.md"

required_phrases=(
  "人才服务区仅展示发布快照"
  "对接接口仅 stub"
  "不输出原始候选人数据"
  "人才服务区"
  "发布快照"
  "原始候选人数据"
  "同意"
  "撤回"
  "对接接口"
  "数据域"
  "字段级权限"
)

implementation_paths=(
  "$ROOT_DIR/backend/src"
  "$ROOT_DIR/backend/pom.xml"
  "$ROOT_DIR/backend/mvnw"
  "$ROOT_DIR/backend/mvnw.cmd"
  "$ROOT_DIR/backend/.mvn"
  "$ROOT_DIR/backend/src/main/resources/application.yaml"
  "$ROOT_DIR/frontend/src"
  "$ROOT_DIR/frontend/package.json"
  "$ROOT_DIR/frontend/vite.config.ts"
  "$ROOT_DIR/frontend/vitest.config.ts"
  "$ROOT_DIR/frontend/tsconfig.json"
  "$ROOT_DIR/frontend/index.html"
  "$ROOT_DIR/infra/docker-compose.yml"
  "$ROOT_DIR/scripts/run_all"
)

if command -v rg >/dev/null 2>&1; then
  search_cmd() {
    rg -i -n "$1" "${implementation_paths[@]}" >/dev/null 2>&1
  }
else
  search_cmd() {
    grep -RIniE "$1" "${implementation_paths[@]}" >/dev/null 2>&1
  }
fi

for phrase in "${required_phrases[@]}"; do
  if ! grep -Fq "$phrase" "$README_FILE"; then
    echo "FAIL: README missing required phrase: $phrase"
    exit 1
  fi
done

forbidden_patterns=(
  "ats client"
  "candidate pool connector"
  "受控候选池连接器"
  "real sync client"
  "candidate_mobile"
  "candidate_email"
  "resume_content"
  "attachment_url"
  "chat_record"
  "evidence_material"
)

for pattern in "${forbidden_patterns[@]}"; do
  if search_cmd "$pattern"; then
    echo "FAIL: forbidden implementation marker detected: $pattern"
    exit 1
  fi
done

prompt3_required_paths=(
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/authz"
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/audit"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/authz/FieldPolicyEngineTest.java"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/authz/DataScopeIntegrationTest.java"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/authz/IdorBlockIntegrationTest.java"
)

for required_path in "${prompt3_required_paths[@]}"; do
  if [ ! -e "$required_path" ]; then
    echo "FAIL: Prompt 3 required path missing: $required_path"
    exit 1
  fi
done

while IFS= read -r controller_file; do
  case "$controller_file" in
    */auth/api/AuthController.java|*/health/HealthController.java)
      ;;
    *)
      if ! grep -Eq "@RequirePermission|@PublicEndpoint" "$controller_file"; then
        echo "FAIL: production controller without @RequirePermission or @PublicEndpoint: $controller_file"
        exit 1
      fi
      ;;
  esac

  if grep -Eiq "mask|MASK|脱敏|\\*\\*\\*" "$controller_file"; then
    echo "FAIL: controller-level masking marker detected: $controller_file"
    exit 1
  fi
done < <(find "$ROOT_DIR/backend/src/main/java" -name '*Controller.java' -type f)

if ! grep -Fq "unconfiguredSensitiveFieldsShouldNotLeak" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/authz/FieldPolicyEngineTest.java"; then
  echo "FAIL: sensitive field no-leak test missing"
  exit 1
fi

if ! grep -Fq "AUTHZ_403" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/authz/IdorBlockIntegrationTest.java"; then
  echo "FAIL: authorization denial integration assertion missing"
  exit 1
fi

prompt4_required_paths=(
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/candidate"
  "$ROOT_DIR/backend/src/main/resources/db/migration/V0006__create_api_idempotency_records.sql"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/candidate/ConsentSnapshotFlowIT.java"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/candidate/PortalFieldBlacklistTest.java"
)

for required_path in "${prompt4_required_paths[@]}"; do
  if [ ! -e "$required_path" ]; then
    echo "FAIL: Prompt 4 required path missing: $required_path"
    exit 1
  fi
done

while IFS= read -r portal_file; do
  if grep -Eiq "candidate_user|candidate_resume" "$portal_file"; then
    echo "FAIL: portal talent snapshot code must not read raw candidate tables: $portal_file"
    exit 1
  fi
done < <(find "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/candidate" -type f \( -name '*Portal*.java' -o -name '*TalentSnapshot*.java' \))

while IFS= read -r response_file; do
  if grep -Eiq "mobile|email|password_hash|resume_body|attachment_object_key|evidence|base_profile_json|education_json|experience_json|skills_json" "$response_file"; then
    echo "FAIL: portal response DTO contains raw candidate field marker: $response_file"
    exit 1
  fi
done < <(find "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/candidate/api" -type f -name '*Snapshot*Response.java')

if ! grep -Fq "IDEMPOTENCY_409" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/candidate/ConsentSnapshotFlowIT.java"; then
  echo "FAIL: Prompt 4 idempotency conflict assertion missing"
  exit 1
fi

if ! grep -Fq "doesNotContain(\"mobile\")" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/candidate/PortalFieldBlacklistTest.java"; then
  echo "FAIL: Prompt 4 portal field blacklist assertion missing"
  exit 1
fi

prompt5_required_paths=(
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/company"
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/job"
  "$ROOT_DIR/backend/src/main/resources/db/migration/V0007__add_company_job_review_fields.sql"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/job/JobVisibilityIT.java"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/job/JobIdorBlockIT.java"
)

for required_path in "${prompt5_required_paths[@]}"; do
  if [ ! -e "$required_path" ]; then
    echo "FAIL: Prompt 5 required path missing: $required_path"
    exit 1
  fi
done

if grep -RIEiq "job_application|interview_session|export_apply|open_api|integration_sync|ats|candidate_pool" \
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/company" \
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/job"; then
  echo "FAIL: Prompt 5 company/job module contains later-scope implementation marker"
  exit 1
fi

if ! grep -Fq "company is not certified" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/job/JobVisibilityIT.java"; then
  echo "FAIL: Prompt 5 uncertified company online-block assertion missing"
  exit 1
fi

if ! grep -Fq "AUTHZ_403" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/job/JobIdorBlockIT.java"; then
  echo "FAIL: Prompt 5 IDOR denial assertion missing"
  exit 1
fi

prompt6_required_paths=(
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/application"
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/interview"
  "$ROOT_DIR/backend/src/main/resources/db/migration/V0008__add_interview_signin_code_fields.sql"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/application/ApplicationInterviewFlowIT.java"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/application/ApplicationIdorBlockIT.java"
)

for required_path in "${prompt6_required_paths[@]}"; do
  if [ ! -e "$required_path" ]; then
    echo "FAIL: Prompt 6 required path missing: $required_path"
    exit 1
  fi
done

if grep -RIEiq "export_apply|open_api|integration_sync|ats|candidate_pool|同意|撤回|publish_snapshot" \
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/application" \
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/interview"; then
  echo "FAIL: Prompt 6 application/interview module contains out-of-scope implementation marker"
  exit 1
fi

if ! grep -Fq "signin_code_hash" \
  "$ROOT_DIR/backend/src/main/resources/db/migration/V0008__add_interview_signin_code_fields.sql"; then
  echo "FAIL: Prompt 6 signin code hash migration missing"
  exit 1
fi

if ! grep -Fq "trace-p6-signin-replay" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/application/ApplicationInterviewFlowIT.java"; then
  echo "FAIL: Prompt 6 replay-block assertion missing"
  exit 1
fi

if ! grep -Fq "trace-p6-signin-expired" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/application/ApplicationInterviewFlowIT.java"; then
  echo "FAIL: Prompt 6 expired-code assertion missing"
  exit 1
fi

if ! grep -Fq "AUTHZ_403" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/application/ApplicationIdorBlockIT.java"; then
  echo "FAIL: Prompt 6 IDOR denial assertion missing"
  exit 1
fi

prompt7_required_paths=(
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/admin"
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/admin/review/api/AdminCompanyReviewController.java"
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/admin/review/api/AdminJobReviewController.java"
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/admin/cms"
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/admin/event"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/admin/ReviewAffectsVisibilityIT.java"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/admin/AdminCmsEventCrudIT.java"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/admin/AuditorWriteDeniedIT.java"
)

for required_path in "${prompt7_required_paths[@]}"; do
  if [ ! -e "$required_path" ]; then
    echo "FAIL: Prompt 7 required path missing: $required_path"
    exit 1
  fi
done

if grep -RIEiq "candidate_user|candidate_resume|activity_registration|export_apply|open_api|integration_sync|ats|candidate_pool" \
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/admin"; then
  echo "FAIL: Prompt 7 admin module contains out-of-scope implementation marker"
  exit 1
fi

if grep -RIEiq "DELETE[[:space:]]+FROM[[:space:]]+(cms_content|activity_event)" \
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/admin"; then
  echo "FAIL: Prompt 7 cms/event must use soft delete, not physical delete"
  exit 1
fi

for api_code in \
  "admin.company.review.read" \
  "admin.company.review.write" \
  "admin.job.review.read" \
  "admin.job.review.write" \
  "admin.cms.read" \
  "admin.cms.write" \
  "admin.event.read" \
  "admin.event.write"; do
  if ! grep -Fq "$api_code" "$ROOT_DIR/backend/src/main/resources/db/migration/R__seed_base_dictionary_roles_menus.sql"; then
    echo "FAIL: Prompt 7 seed permission missing: $api_code"
    exit 1
  fi
done

if ! grep -Fq "trace-p7-portal-job-visible" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/admin/ReviewAffectsVisibilityIT.java"; then
  echo "FAIL: Prompt 7 review visibility assertion missing"
  exit 1
fi

if ! grep -Fq "cms_soft_delete" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/admin/AdminCmsEventCrudIT.java"; then
  echo "FAIL: Prompt 7 cms soft-delete audit assertion missing"
  exit 1
fi

if ! grep -Fq "event_soft_delete" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/admin/AdminCmsEventCrudIT.java"; then
  echo "FAIL: Prompt 7 event soft-delete audit assertion missing"
  exit 1
fi

if ! grep -Fq "AUTHZ_403" \
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/admin/AuditorWriteDeniedIT.java"; then
  echo "FAIL: Prompt 7 auditor write-denial assertion missing"
  exit 1
fi

prompt8_required_paths=(
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/exporting"
  "$ROOT_DIR/backend/src/main/resources/db/migration/V0009__extend_export_apply_for_minio_download.sql"
  "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/exporting/ExportApprovalFlowIT.java"
)

for required_path in "${prompt8_required_paths[@]}"; do
  if [ ! -e "$required_path" ]; then
    echo "FAIL: Prompt 8 required path missing: $required_path"
    exit 1
  fi
done

if grep -RIEiq "open_api|integration_sync|ats|candidate_pool|activity_registration" \
  "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/exporting"; then
  echo "FAIL: Prompt 8 export module contains out-of-scope implementation marker"
  exit 1
fi

while IFS= read -r response_file; do
  if grep -Eiq "mobile|email|resume_body|attachment_object_key|evidence" "$response_file"; then
    echo "FAIL: Prompt 8 export API response DTO contains raw candidate field marker: $response_file"
    exit 1
  fi
done < <(find "$ROOT_DIR/backend/src/main/java/cn/localtalent/backend/exporting/api" -type f -name '*Response.java')

for api_code in \
  "company.export.apply" \
  "company.export.read" \
  "company.export.download" \
  "admin.export.review.read" \
  "admin.export.review.write"; do
  if ! grep -Fq "$api_code" "$ROOT_DIR/backend/src/main/resources/db/migration/R__seed_base_dictionary_roles_menus.sql"; then
    echo "FAIL: Prompt 8 seed permission missing: $api_code"
    exit 1
  fi
done

for assertion_marker in \
  "trace-p8-download-unapproved" \
  "trace-p8-url-expired" \
  "field_access_log" \
  "export_download_url_issue"; do
  if ! grep -Fq "$assertion_marker" "$ROOT_DIR/backend/src/test/java/cn/localtalent/backend/exporting/ExportApprovalFlowIT.java"; then
    echo "FAIL: Prompt 8 export approval assertion missing: $assertion_marker"
    exit 1
  fi
done

echo "PASS"
