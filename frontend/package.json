{
  "name": "localtalent-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "test": "vitest run --config vitest.config.ts --maxWorkers 1 --no-file-parallelism --pool threads",
    "test:watch": "vitest --config vitest.config.ts --maxWorkers 1 --no-file-parallelism --pool threads"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "^26.1.0",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "4.1.4"
  }
}
